<input type="range" min="0" max="50" step="0.1" value="10" class="slider" oninput="setPID()"><br><br>
Kd: <span id="kdv">0.05</span><br>
<input type="range" min="0" max="50" step="0.05" value="0.05" class="slider" oninput="setPID()"><br><br>
Ki: <span id="kiv">40</span><br>
<input type="range" min="0" max="100" step="0.05" value="40" class="slider" oninput="setPID()"><br><br>
Max PWM: <span id="maxv">80</span><br>
<input type="range" min="0" max="255" step="1" value="80" class="slider" oninput="setPID()"><br><br>
