#include <WiFi.h>
#include <WebServer.h>
#include <Wire.h>
#include <BMI160Gen.h>
#include "math.h"

/******** WIFI ********/
const char* ssid = "ESP32_Robot";
const char* password = "12345678";
WebServer server(80);

/******** IMU ********/
#define SDA_PIN 25
#define SCL_PIN 26
#define IMU_ADDR 0x68

#define ACC_SCALE 0.00006103515f
#define GYRO_SCALE 0.00763358f

/******** MOTOR ********/
const int pwmPinL = 27;
const int dirPinL = 14;
const int pwmPinR = 33;
const int dirPinR = 32;

int maxPWM = 80;
int minPWM = 5;

/******** PID ********/
float Kp  = 10;
float Kd  = 0.05;
float Ki  = 40;
#define sampleTime  0.005
#define targetAngle 0

/******** STATE ********/
volatile int16_t accY, accZ, gyroX;

volatile float accAngle, gyroAngle;
volatile float currentAngle = 0, prevAngle = 0;
volatile float error, errorSum = 0;
volatile float pitchRate = 0;
volatile int motorPower = 0;

/******** SMOOTHING STATE ********/
volatile float movementAngle = 0;
volatile float smoothTurnL = 0;
volatile float smoothTurnR = 0;

/******** MOTOR STATE ********/
volatile int pwmL = 0, pwmR = 0;
volatile int dirL = 1, dirR = 0;

/******** GYRO ********/
float gyroBiasX = 0;

/******** REFERENCE ********/
float referenceAngle = 0;

/******** DERIVATIVE ********/
float prevCompAngle = 0;

/******** COMMAND ********/
volatile char command = 'S';           
volatile unsigned long lastCmdTime = 0;  

