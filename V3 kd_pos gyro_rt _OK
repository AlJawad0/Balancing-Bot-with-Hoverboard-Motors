    } catch (e) {
      alert('Error requesting permission: ' + e);
    }
  } else {
    // Non-iOS 13+ devices
    enableTilt();
  }
}

function enableTilt() {
  if (tiltActive) return;
  tiltActive = true;
  
  document.getElementById('startBtn').style.background = '#4444ff';
  document.getElementById('startBtn').innerText = 'CONTROL ACTIVE';
  
  window.addEventListener('deviceorientation', (e) => {
    let b = e.beta;   // Pitch: -180 to 180
    let g = e.gamma;  // Roll: -90 to 90
    
    // Debug display
    document.getElementById('rawTilt').innerText = 'P:' + (b?b.toFixed(0):'-') + ' R:' + (g?g.toFixed(0):'-');
    
    let newCmd = 'S';
    
    if (b > 50) newCmd = 'B';
    else if (b < -5) newCmd = 'F';
    else if (g > 20) newCmd = 'R';
    else if (g < -20) newCmd = 'L';
    
    if (newCmd !== currentCmd) {
      currentCmd = newCmd;
      document.getElementById('cmdDisp').innerText = currentCmd;
      fetch(`/cmd?v=${currentCmd}`);
    }
  });
}

