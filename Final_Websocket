</style>
</head><body>

<h2>Robot Dashboard</h2>

<div class="grid">
<div class="card"><div>Pitch</div><div id="pitch" class="val">0</div></div>
<div class="card"><div>Diff</div><div id="diff" class="val">0</div></div>
<div class="card"><div>Pitch Rate</div><div id="rate" class="val">0</div></div>
<div class="card"><div>Error Sum</div><div id="sum" class="val">0</div></div>
<div class="card"><div>PWM L</div><div id="pwmL" class="val">0</div></div>
<div class="card"><div>PWM R</div><div id="pwmR" class="val">0</div></div>
