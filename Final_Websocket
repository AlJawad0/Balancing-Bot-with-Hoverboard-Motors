/******** WEBSOCKET EVENT HANDLER ********/
void onWsEvent(AsyncWebSocket *server, AsyncWebSocketClient *client, AwsEventType type, void *arg, uint8_t *data, size_t len) {
  // Empty, strictly handled natively
}

/******** WEBSOCKET TELEMETRY (Called from Core 1) ********/
void broadcastTelemetry() {
  if (ws.count() > 0) {
    char json[200];
    snprintf(json, sizeof(json), 
      "{\"pitch\":\"%.2f\",\"diff\":\"%.2f\",\"rate\":\"%.2f\",\"sum\":\"%.2f\",\"pwmL\":%d,\"pwmR\":%d,\"dirL\":%d,\"dirR\":%d}", 
      currentAngle, error, pitchRate, errorSum, pwmL, pwmR, dirL, dirR);
    ws.textAll(json);
  }
}

/******** TASK SAFE CALIBRATION ********/
// Runs safely inside control task using FreeRTOS Delays 
// Prevents watchdog panics on Core 1
void calibRoutineTaskSafe() {
  int gx, gy, gz;
  long sumX = 0;
  for(int i = 0; i < 500; i++){
    BMI160.readGyro(gx, gy, gz);
    sumX += gx;
    vTaskDelay(pdMS_TO_TICKS(2));
  }
  gyroBiasX = (sumX / 500.0f) * GYRO_SCALE;

  long sumY = 0, sumZ = 0;
  int ax, ay, az;
  for(int i = 0; i < 200; i++){
    BMI160.readAccelerometer(ax, ay, az);
    sumY += ay;
    sumZ += az;
    vTaskDelay(pdMS_TO_TICKS(2));
  }
  float avgY = sumY / 200.0f;
  float avgZ = sumZ / 200.0f;
  referenceAngle = atan2(avgY, avgZ) * RAD_TO_DEG;

  prevAngle = 0;
  currentAngle = 0;
  prevCompAngle = 0;
  errorSum = 0;
}

/******** ASYNC NETWORK SETUP ********/
void setupWiFi() {
  WiFi.softAP(ssid, password);

  ws.onEvent(onWsEvent);
  server.addHandler(&ws);

  server.on("/", HTTP_GET, [](AsyncWebServerRequest *request){
    request->send(200, "text/html", getHTML());
  });

  server.on("/set", HTTP_GET, [](AsyncWebServerRequest *request){
    if(request->hasParam("kp")) Kp = request->getParam("kp")->value().toFloat();
    if(request->hasParam("kd")) Kd = request->getParam("kd")->value().toFloat();
    if(request->hasParam("ki")) Ki = request->getParam("ki")->value().toFloat();
    if(request->hasParam("maxp")) maxPWM = request->getParam("maxp")->value().toInt();
    if(request->hasParam("minp")) minPWM = request->getParam("minp")->value().toInt();
    request->send(200, "text/plain", "OK");
  });

  server.on("/cmd", HTTP_GET, [](AsyncWebServerRequest *request){
    if(request->hasParam("v")){
      command = request->getParam("v")->value().charAt(0);
      cmdTimeoutCounter = 0; // Reset tick-based timeout counter
    }
    request->send(200, "text/plain", "OK");
  });

  server.on("/calibrate", HTTP_GET, [](AsyncWebServerRequest *request){
    requestCalibration = true; // Signal Core 1 to recalibrate safely
    request->send(200, "text/plain", "Calibrating... KEEP STILL");
  });

  server.begin();
}

/******** THE CORE CONTROL TASK (Runs on Core 1) ********/
void controlTask(void *pvParameters) {
  TickType_t xLastWakeTime = xTaskGetTickCount();
  const TickType_t xFrequency = pdMS_TO_TICKS(2.5); // Fixed 400Hz clock
  int cycleCounter = 0;
  int wsCounter = 0;

  while(1) {
    // 1. Wait for deterministic 2.5ms tick
    vTaskDelayUntil(&xLastWakeTime, xFrequency);

    // Dynamic Runtime Calibration Execution
    if (requestCalibration) {
      analogWrite(pwmPinL, 0);
      analogWrite(pwmPinR, 0);
      calibRoutineTaskSafe();
      requestCalibration = false;
      xLastWakeTime = xTaskGetTickCount(); // Synchronize schedule post-calib
      continue;
    }

    // 2. FAST SENSOR READ (400Hz)
    int ax, ay, az, gx, gy, gz;
    BMI160.readMotionSensor(ax, ay, az, gx, gy, gz);
    
    // 3. COMPLEMENTARY FILTER (400Hz)
    float accAngleRaw = atan2(ay, az) * RAD_TO_DEG;
    float gyroRate = (gx * GYRO_SCALE) - gyroBiasX;
    
    float gyroAngle = gyroRate * SAMPLE_TIME_400HZ;
    float rawAngle = 0.9934f * (prevAngle + gyroAngle) + 0.0066f * accAngleRaw;
    
    currentAngle = rawAngle - referenceAngle;
    prevAngle = rawAngle;

    // 4. DECIMATED PID CONTROL (100Hz - Every 4th Cycle)
    cycleCounter++;
    if (cycleCounter >= 4) {
      cycleCounter = 0;

      // Tick-based Command Timeout (1000ms = 100 cycles at 100Hz)
      cmdTimeoutCounter++;
      if (cmdTimeoutCounter > 100) {
        command = 'S';
      }

      // Target Kinematics
      float targetTilt = 0;
      float targetTurnL = 0;
      float targetTurnR = 0;

      if (command == 'F') { targetTilt = -1.5; } 
      else if (command == 'B') { targetTilt = 1.5; }
      else if (command == 'L') { targetTurnR = 25.0; }
      else if (command == 'R') { targetTurnL = 25.0; }

      // Smoothing Low-Pass
      movementAngle = (movementAngle * 0.95f) + (targetTilt * 0.05f);
      smoothTurnL = (smoothTurnL * 0.90f) + (targetTurnL * 0.10f);
      smoothTurnR = (smoothTurnR * 0.90f) + (targetTurnR * 0.10f);

      // PID Math
      error = currentAngle - (TARGET_ANGLE + movementAngle);
      pitchRate = (currentAngle - prevCompAngle) / PID_TIME_100HZ; 

      if (command == 'S') {
         errorSum += error;
         errorSum = constrain(errorSum, -300, 300);
      }

      int motorPowerRaw = (Kp * error) + (Ki * errorSum * PID_TIME_100HZ) + (Kd * pitchRate); 
      prevCompAngle = currentAngle; 

      // 5. MOTOR EXECUTION & HARDWARE PWM
      if (fabs(currentAngle) < 25.0f) { 
        int mpL = motorPowerRaw + smoothTurnL;
        int mpR = motorPowerRaw + smoothTurnR;

        // Left Motor
        if (mpL > 0) { dirL = 1; pwmL = mpL + minPWM; } 
        else { dirL = 0; pwmL = -mpL + minPWM; }
        pwmL = constrain(pwmL, 0, maxPWM);   

        // Right Motor
        if (mpR > 0) { dirR = 0; pwmR = mpR + minPWM; } 
        else { dirR = 1; pwmR = -mpR + minPWM; }
        pwmR = constrain(pwmR, 0, maxPWM);

      } else {
        pwmL = 0;
        pwmR = 0;
        errorSum = 0; // Reset windup
      }

      digitalWrite(dirPinL, dirL);
      digitalWrite(dirPinR, dirR);
      analogWrite(pwmPinL, pwmL);
      analogWrite(pwmPinR, pwmR);

      // 6. STREAM TELEMETRY (20Hz broadcast to not flood WiFi stack)
      wsCounter++;
      if(wsCounter >= 5) {
         wsCounter = 0;
         broadcastTelemetry();

         // Format for Serial Plotter: Angle, Target, and Motor Power
         Serial.print(currentAngle); 
         Serial.print(",");
         Serial.print(movementAngle); // Your shifting target
         Serial.print(",");
         Serial.println(pwmL);
         Serial.print(",");
         Serial.println(command);
      }
    }
  }
}

/******** INITIALIZATION ********/
void setup() {
  Serial.begin(115200);

  pinMode(pwmPinL, OUTPUT);
  pinMode(dirPinL, OUTPUT);
  pinMode(pwmPinR, OUTPUT);
  pinMode(dirPinR, OUTPUT);

  // Forced hardware constraint: 400KHz I2C
  Wire.begin(SDA_PIN, SCL_PIN);
  Wire.setClock(400000); 
  
  BMI160.begin(BMI160GenClass::I2C_MODE, IMU_ADDR);

  // Initial Boot Calibration
  calibRoutineTaskSafe();
  
  // Set up Networking (Hooks natively onto Core 0 via AsyncWebServer)
  setupWiFi();

  // Spin up strict deterministic Task onto Core 1
  xTaskCreatePinnedToCore(controlTask, "CTRL", 4096, NULL, 3, NULL, 1);
}

/******** MAIN THREAD (Core 0) ********/
void loop() {
  // Empty loop architecture. FreeRTOS Tasks handle execution.
  // We only run native socket cleanup here on Core 0.
  ws.cleanupClients();
  vTaskDelay(pdMS_TO_TICKS(100)); 
}
