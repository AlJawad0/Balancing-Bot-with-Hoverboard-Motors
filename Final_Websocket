#include <WiFi.h>
#include <AsyncTCP.h>
#include <ESPAsyncWebServer.h>
#include <Wire.h>
#include <BMI160Gen.h>
#include <math.h>

/******** TIMING & EXECUTION CONSTANTS ********/
#define SAMPLE_TIME_400HZ 0.0025f // 400Hz = 2.5ms
#define PID_TIME_100HZ    0.0100f // 100Hz = 10.0ms
#define TARGET_ANGLE      0.0f

/******** WIFI ********/
const char* ssid = "ESP32_Robot";
const char* password = "12345678";
AsyncWebServer server(80);
AsyncWebSocket ws("/ws");

/******** IMU SENSOR ********/
#define SDA_PIN 25
#define SCL_PIN 26
#define IMU_ADDR 0x68

#define ACC_SCALE 0.00006103515f
#define GYRO_SCALE 0.00763358f

/******** MOTOR PINS ********/
const int pwmPinL = 27;
const int dirPinL = 14;
const int pwmPinR = 33;
const int dirPinR = 32;

/******** SHARED GLOBAL STATE (Volatile) ********/
volatile float Kp = 10.0f, Ki = 40.0f, Kd = 0.05f;
volatile int maxPWM = 80, minPWM = 5;

volatile float currentAngle = 0.0f, prevAngle = 0.0f;
volatile float error = 0.0f, pitchRate = 0.0f, errorSum = 0.0f;
volatile float movementAngle = 0.0f, smoothTurnL = 0.0f, smoothTurnR = 0.0f;
volatile float prevCompAngle = 0.0f;
volatile float gyroBiasX = 0.0f, referenceAngle = 0.0f;

volatile int pwmL = 0, pwmR = 0;
volatile int dirL = 1, dirR = 0;

volatile char command = 'S';           
volatile uint32_t cmdTimeoutCounter = 0; // Replaces millis() for timing
volatile bool requestCalibration = false;

/******** HTML & JAVASCRIPT ********/
String getHTML() {
  return R"rawliteral(
