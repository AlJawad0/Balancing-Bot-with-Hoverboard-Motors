/******** WIFI ********/
void setupWiFi(){

  WiFi.softAP(ssid,password);

  server.on("/",[](){
    server.send(200,"text/html",getHTML());
  });

  server.on("/data",[](){
    char json[200];
    snprintf(json,sizeof(json),
      "{\"pitch\":%.2f,\"diff\":%.2f,\"rate\":%.2f,\"sum\":%.2f,\"pwmL\":%d,\"pwmR\":%d,\"dirL\":%d,\"dirR\":%d}",
      currentAngle,
      error,
      pitchRate,
      errorSum,
      pwmL, pwmR,
      dirL, dirR
    );
    server.send(200,"application/json",json);
  });

  server.on("/set",[](){
    if(server.hasArg("kp")) Kp = server.arg("kp").toFloat();
    if(server.hasArg("kd")) Kd = server.arg("kd").toFloat();
    if(server.hasArg("ki")) Ki = server.arg("ki").toFloat();
    if(server.hasArg("maxp")) maxPWM = server.arg("maxp").toInt();
    if(server.hasArg("minp")) minPWM = server.arg("minp").toInt();
    server.send(200,"text/plain","OK");
  });

  server.on("/cmd", [](){
    if(server.hasArg("v")){
      command = server.arg("v")[0];
      lastCmdTime = millis(); 
    }
    server.send(200, "text/plain", "OK");
  });

  server.on("/calibrate",[](){
    pwmL = pwmR = 0;
    analogWrite(pwmPinL, 0);
    analogWrite(pwmPinR, 0);

    server.send(200,"text/plain","Calibrating... KEEP STILL");
    delay(200);
    calibrateGyro();

    long sumY=0, sumZ=0;
    int ax,ay,az;
    for(int i=0;i<200;i++){
      BMI160.readAccelerometer(ax,ay,az);
      sumY += ay;
      sumZ += az;
      delay(2);
    }
    accY = sumY / 200;
    accZ = sumZ / 200;
    referenceAngle = atan2(accY, accZ)*RAD_TO_DEG;

    prevAngle = 0;
    currentAngle = 0;
    prevCompAngle = 0;
    errorSum = 0;
  });

  server.begin();
}

/******** GYRO CAL ********/
void calibrateGyro(){
  delay(2000);
  int gx,gy,gz;
  long sum=0;
  for(int i=0;i<500;i++){
    BMI160.readGyro(gx,gy,gz);
    sum += gx;
    delay(2);
  }
  gyroBiasX = (sum/500.0f) * GYRO_SCALE;
}

/******** CONTROL TASK ********/
void controlTask(void *pv){
  TickType_t xLastWakeTime = xTaskGetTickCount();

  while(1){
    vTaskDelayUntil(&xLastWakeTime, pdMS_TO_TICKS(5));

    // 1. READ SENSORS
    int ax,ay,az,gx,gy,gz;
    BMI160.readAccelerometer(ax,ay,az);
    BMI160.readGyro(gx,gy,gz);

    accY = ay;
    accZ = az;
    gyroX = gx;
    accAngle = atan2(accY, accZ)*RAD_TO_DEG;

    float gyroRate = (gyroX * GYRO_SCALE) - gyroBiasX;
    gyroAngle = gyroRate * sampleTime;

    float rawAngle = 0.9934*(prevAngle + gyroAngle) + 0.0066*(accAngle);
    currentAngle = rawAngle - referenceAngle;

    // 2. COMMAND TIMEOUT & SMOOTHING
    if (millis() - lastCmdTime > 1000) {  // 1 Sec Timeout
      command = 'S';
    }

    float targetTilt = 0;
    float targetTurnL = 0;
    float targetTurnR = 0;

    // Forward/Backward Tilt-To-Translate
    if (command == 'F') { targetTilt = -2.5; } 
    else if (command == 'B') { targetTilt = 2.5; }
    
    // Additive non-differential turning 
    else if (command == 'L') { targetTurnR = 20.0; } // Only right wheel pushes
    else if (command == 'R') { targetTurnL = 20.0; } // Only left wheel pushes

    // Low-Pass Filter for smooth ramping
    movementAngle = (movementAngle * 0.95) + (targetTilt * 0.05);
    smoothTurnL = (smoothTurnL * 0.90) + (targetTurnL * 0.10);
    smoothTurnR = (smoothTurnR * 0.90) + (targetTurnR * 0.10);

    // 3. PID MATH
    // Error is calculated against the dynamically shifting target
    error = currentAngle - (targetAngle + movementAngle);
    pitchRate = (currentAngle - prevCompAngle) / sampleTime; 

    // Only let Ki build up if we are NOT actively trying to move
    if (command == 'S') {
       errorSum += error;
       errorSum = constrain(errorSum, -300, 300);
    }

    // Notice Kd and Ki are both POSITIVE additions (+)
    motorPower = (Kp * error) + (Ki * errorSum * sampleTime) + (Kd * pitchRate); 
    
    prevAngle = rawAngle;
    prevCompAngle = currentAngle; 

    // 4. MOTOR CONTROL EXECUTION
    // Use raw currentAngle for crash-detection safety, not the shifted error
    if (fabs(currentAngle) < 25) { 
      
      int mpL = motorPower + smoothTurnL;
      int mpR = motorPower + smoothTurnR;

      // Left Motor Logic
      if (mpL > 0) {
        dirL = 1;
        pwmL = mpL;
      } else {
        dirL = 0;
        pwmL = -mpL;
      }
      if (pwmL > 0) pwmL += minPWM;        
      pwmL = constrain(pwmL, 0, maxPWM);   

      // Right Motor Logic (inverted direction)
      if (mpR > 0) {
        dirR = 0;
        pwmR = mpR;
      } else {
        dirR = 1;
        pwmR = -mpR;
      }
      if (pwmR > 0) pwmR += minPWM;
      pwmR = constrain(pwmR, 0, maxPWM);

    } else {
      pwmL = 0;
      pwmR = 0;
      errorSum = 0; // Reset windup on crash
    }

    digitalWrite(dirPinL, dirL);
    digitalWrite(dirPinR, dirR);
    analogWrite(pwmPinL, pwmL);
    analogWrite(pwmPinR, pwmR);
  }
}

/******** WEB TASK ********/
void webTask(void *pv) {
  while (1) {
    server.handleClient();
    vTaskDelay(1);  // yield CPU
  }
}

/******** SETUP ********/
void setup(){
  Serial.begin(115200);

  pinMode(pwmPinL,OUTPUT);
  pinMode(dirPinL,OUTPUT);
  pinMode(pwmPinR,OUTPUT);
  pinMode(dirPinR,OUTPUT);

  Wire.begin(SDA_PIN,SCL_PIN);
  BMI160.begin(BMI160GenClass::I2C_MODE,IMU_ADDR);

  delay(1000);

  long sumY = 0, sumZ = 0;
  int ax, ay, az;
  for(int i=0;i<300;i++){
    BMI160.readAccelerometer(ax,ay,az);
    sumY += ay;
    sumZ += az;
    delay(5);
  }
  float avgY = sumY / 300.0;
  float avgZ = sumZ / 300.0;
  referenceAngle = atan2(avgY, avgZ) * RAD_TO_DEG;

  prevAngle = referenceAngle;
  currentAngle = 0;
  prevCompAngle = 0;
  errorSum = 0;

  calibrateGyro();
  setupWiFi();

  // Core 0 handles Web Server
  xTaskCreatePinnedToCore(webTask, "WEB", 4096, NULL, 1, NULL, 0);

  // Core 1 strictly handles high-speed balancing
  xTaskCreatePinnedToCore(controlTask,"CTRL",4096,NULL,3,NULL,1);
}

/******** LOOP ********/
void loop(){
  // Loop is now intentionally left empty! 
  // FreeRTOS tasks (CTRL and WEB) are handling everything in the background.
  delay(1000); 
}
