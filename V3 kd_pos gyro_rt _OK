/******** WIFI ********/
void setupWiFi(){

  WiFi.softAP(ssid,password);

  server.on("/",[](){
    server.send(200,"text/html",getHTML());
  });

  server.on("/data",[](){
    char json[200];
    snprintf(json,sizeof(json),
      "{\"pitch\":%.2f,\"diff\":%.2f,\"rate\":%.2f,\"sum\":%.2f,\"pwmL\":%d,\"pwmR\":%d,\"dirL\":%d,\"dirR\":%d}",
      currentAngle,
      error,
      pitchRate,
      errorSum,
      pwmL, pwmR,
      dirL, dirR
    );
    server.send(200,"application/json",json);
  });

  server.on("/set",[](){
    if(server.hasArg("kp")) Kp = server.arg("kp").toFloat();
    if(server.hasArg("kd")) Kd = server.arg("kd").toFloat();
    if(server.hasArg("ki")) Ki = server.arg("ki").toFloat();
    if(server.hasArg("maxp")) maxPWM = server.arg("maxp").toInt();
    if(server.hasArg("minp")) minPWM = server.arg("minp").toInt();
    server.send(200,"text/plain","OK");
  });

  // Command endpoint - receives F/B/L/R/S from phone tilt
  server.on("/cmd", [](){
    if(server.hasArg("v")){
      command = server.arg("v")[0];
      lastCmdTime = millis();   // FIX: track freshness
    }
    server.send(200, "text/plain", "OK");
  });

  server.on("/calibrate",[](){

    pwmL = pwmR = 0;
    analogWrite(pwmPinL, 0);
    analogWrite(pwmPinR, 0);

    server.send(200,"text/plain","Calibrating... KEEP STILL");

    delay(200);

    calibrateGyro();

    long sumY=0, sumZ=0;
    int ax,ay,az;

    for(int i=0;i<200;i++){
      BMI160.readAccelerometer(ax,ay,az);
      sumY += ay;
      sumZ += az;
      delay(2);
    }

    accY = sumY / 200;
    accZ = sumZ / 200;

    referenceAngle = atan2(accY, accZ)*RAD_TO_DEG;

    prevAngle = 0;
    currentAngle = 0;
    prevCompAngle = 0;

    errorSum = 0;
  });

  server.begin();
}

/******** GYRO CAL ********/
void calibrateGyro(){

  delay(2000);

  int gx,gy,gz;
  long sum=0;

  for(int i=0;i<500;i++){
    BMI160.readGyro(gx,gy,gz);
    sum += gx;
    delay(2);
  }

  gyroBiasX = (sum/500.0f) * GYRO_SCALE;
}

/******** CONTROL TASK ********/
void controlTask(void *pv){

  TickType_t xLastWakeTime = xTaskGetTickCount();

  while(1){

    vTaskDelayUntil(&xLastWakeTime, pdMS_TO_TICKS(5));


    int ax,ay,az,gx,gy,gz;

    BMI160.readAccelerometer(ax,ay,az);
    BMI160.readGyro(gx,gy,gz);

    accY = ay;
    accZ = az;
    gyroX = gx;
    accAngle = atan2(accY, accZ)*RAD_TO_DEG;

    float gyroRate = (gyroX * GYRO_SCALE) - gyroBiasX;
    gyroAngle = gyroRate * sampleTime;

    float rawAngle =
      0.9934*(prevAngle + gyroAngle)
    + 0.0066*(accAngle);

    currentAngle = rawAngle - referenceAngle;

    error = currentAngle - targetAngle;

    errorSum += error;
    errorSum = constrain(errorSum, -300, 300);

    pitchRate = (currentAngle - prevCompAngle) / sampleTime;  // 1. SAVE the rate

    motorPower = (Kp * error) + (Ki * errorSum * sampleTime) + (Kd * pitchRate);  // 2. Use saved rate

    prevAngle = rawAngle;
    prevCompAngle = currentAngle;  // 3. Update AFTER saving rate
  }
}

/******** WEB TASK ********/
// FIX: Added new webTask to run on Core 0
void webTask(void *pv) {
  while (1) {
    server.handleClient();
    vTaskDelay(1);  // yield CPU (VERY IMPORTANT)
  }
}

/******** SETUP ********/
void setup(){

  Serial.begin(115200);

  pinMode(pwmPinL,OUTPUT);
  pinMode(dirPinL,OUTPUT);
  pinMode(pwmPinR,OUTPUT);
  pinMode(dirPinR,OUTPUT);

  Wire.begin(SDA_PIN,SCL_PIN);
  BMI160.begin(BMI160GenClass::I2C_MODE,IMU_ADDR);

  delay(1000);

  long sumY = 0, sumZ = 0;
  int ax, ay, az;

  for(int i=0;i<300;i++){
    BMI160.readAccelerometer(ax,ay,az);
    sumY += ay;
    sumZ += az;
    delay(5);
  }

  float avgY = sumY / 300.0;
  float avgZ = sumZ / 300.0;

  referenceAngle = atan2(avgY, avgZ) * RAD_TO_DEG;

  prevAngle = referenceAngle;
  currentAngle = 0;
  prevCompAngle = 0;

  errorSum = 0;

  calibrateGyro();

  setupWiFi();

  // FIX: Start web task on Core 0
  xTaskCreatePinnedToCore(webTask, "WEB", 4096, NULL, 1, NULL, 0);

  xTaskCreatePinnedToCore(controlTask,"CTRL",4096,NULL,3,NULL,1);
}

/******** LOOP ********/
void loop(){


  // FIX: FAILSAFE: stop if no command received recently
  if (millis() - lastCmdTime > 300) {
    command = 'S';
  }

  if (fabs(error) < 25) {
    
    // Start with base balancing power for both motors
    int mpL = motorPower;
    int mpR = motorPower;

    // Apply tilt commands (±5 PWM) FIRST
    if (command == 'F') { mpL += 20; mpR += 20; }
    else if (command == 'B') { mpL -= 20; mpR -= 20; }
    else if (command == 'L') { mpR += 20; }
    else if (command == 'R') { mpL += 20; }

    // Left Motor Logic
    if (mpL > 0) {
      dirL = 1;
      pwmL = mpL;
    } else {
      dirL = 0;
      pwmL = -mpL;
    }
    if (pwmL > 0) pwmL += minPWM;        // Add minPWM AFTER assignment
    pwmL = constrain(pwmL, 0, maxPWM);   // Constrain AFTER minPWM

    // Right Motor Logic (inverted direction)
    if (mpR > 0) {
      dirR = 0;
      pwmR = mpR;
    } else {
      dirR = 1;
      pwmR = -mpR;
    }
    if (pwmR > 0) pwmR += minPWM;
    pwmR = constrain(pwmR, 0, maxPWM);

  } else {
    pwmL = 0;
    pwmR = 0;
  }

  digitalWrite(dirPinL, dirL);
  digitalWrite(dirPinR, dirR);
  analogWrite(pwmPinL, pwmL);
  analogWrite(pwmPinR, pwmR);
