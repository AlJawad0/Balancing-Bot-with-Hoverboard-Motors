let currentCmd = 'S';
let tiltActive = false;

// Async WebSocket Setup
var gateway = `ws://${window.location.hostname}/ws`;
var websocket;

window.onload = () => {
  websocket = new WebSocket(gateway);
  websocket.onmessage = (e) => {
    let d = JSON.parse(e.data);
    document.getElementById('pitch').innerText = d.pitch;
    document.getElementById('diff').innerText = d.diff;
    document.getElementById('rate').innerText = d.rate;
    document.getElementById('sum').innerText = d.sum;
    document.getElementById('pwmL').innerText = d.pwmL;
    document.getElementById('pwmR').innerText = d.pwmR;
    document.getElementById('dirL').innerText = d.dirL;
    document.getElementById('dirR').innerText = d.dirR;
  };
};

function setPID(){
  let s=document.querySelectorAll('.slider');
  let kp=s[0].value, kd=s[1].value, ki=s[2].value, maxp=s[3].value, minp=s[4].value;

  kpv.innerText=kp; kdv.innerText=kd; kiv.innerText=ki; maxv.innerText=maxp; minv.innerText=minp;
  fetch(`/set?kp=${kp}&kd=${kd}&ki=${ki}&maxp=${maxp}&minp=${minp}`);
}

function calibrate(){
  fetch('/calibrate');
}

async function startTilt() {
  if (typeof DeviceOrientationEvent !== 'undefined' && typeof DeviceOrientationEvent.requestPermission === 'function') {
    try {
      const permission = await DeviceOrientationEvent.requestPermission();
      if (permission === 'granted') enableTilt();
      else alert('Permission denied.');
    } catch (e) { alert('Error: ' + e); }
  } else {
    enableTilt();
  }
}

function enableTilt() {
  if (tiltActive) return;
  tiltActive = true;
  document.getElementById('startBtn').style.background = '#4444ff';
  document.getElementById('startBtn').innerText = 'CONTROL ACTIVE';
  
  window.addEventListener('deviceorientation', (e) => {
    let b = e.beta, g = e.gamma;
    document.getElementById('rawTilt').innerText = 'P:' + (b?b.toFixed(0):'-') + ' R:' + (g?g.toFixed(0):'-');
    
    let newCmd = 'S';
    if (b > 50) newCmd = 'B';
    else if (b < -5) newCmd = 'F';
    else if (g > 20) newCmd = 'R';
    else if (g < -20) newCmd = 'L';
    
    if (newCmd !== currentCmd) {
      currentCmd = newCmd;
      document.getElementById('cmdDisp').innerText = currentCmd;
      fetch(`/cmd?v=${currentCmd}`);
    }
  });
}
</script>
